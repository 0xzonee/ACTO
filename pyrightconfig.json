{
    "include": [
        "acto",
        "acto_cli",
        "acto_server",
        "tests"
    ],
    "exclude": [
        "**/__pycache__",
        "**/node_modules",
        "**/.venv",
        "**/venv"
    ],
    "reportMissingImports": "warning",
    "reportMissingTypeStubs": false,
    "pythonVersion": "3.10",
    "typeCheckingMode": "basic",
    "ignore": [
        "tests/load/locustfile.py",
        "tests/test_property_based.py"
    ]
}

